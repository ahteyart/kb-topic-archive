# ---- Supabase ----
# 项目设置 → API 里可以找到
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# publishable key(sb_publishable_… 或 legacy anon key),可安全暴露到浏览器
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# ---- AI 自动标签(仅服务端使用,不要加 NEXT_PUBLIC_ 前缀)----
# DeepSeek 优先(便宜)。留空时「AI 自动生成」会回退到本地英文关键词提取。
DEEPSEEK_API_KEY=
# 可选:想改用 Claude 时填入
ANTHROPIC_API_KEY=

# ---- 可选 ----
# service role key(仅服务端;当前应用逻辑不需要,留作管理脚本/后续用途)
# SUPABASE_SERVICE_ROLE_KEY=
